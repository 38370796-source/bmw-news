# LLM API Key（必需，推荐 DeepSeek：https://platform.deepseek.com/api_keys）
LLM_API_KEY=your_api_key_here

# LLM 配置（可选，默认使用 DeepSeek）
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# BATCH_SIZE=15

# 代理开关（可选，默认 false=不使用代理。如需代理，设为 true 并填写下方代理地址）
# USE_PROXY=true

# 代理配置（USE_PROXY=true 时生效）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 目标 URL（可选）
# BLOOMBERG_URL=https://www.bloomberg.com/asia
