# LLM API Key（必需，推荐 DeepSeek：https://platform.deepseek.com/api_keys）
LLM_API_KEY=your_api_key_here

# LLM 配置（可选，默认使用 DeepSeek）
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# BATCH_SIZE=15

# 代理开关（默认 true=使用代理。如不需要代理，设为 false）
# USE_PROXY=false

# 代理配置（默认 127.0.0.1:7890，按需修改）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 新闻网址（逗号分隔，可自定义多个来源）
NEWS_URLS=https://www.bloomberg.com/asia,https://www.cnbc.com/world/?region=world
